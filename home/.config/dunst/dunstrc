[global]
    monitor = 0
    follow = mouse
    width = 360
    height = (0, 140)
    origin = top-right
    offset = (20, 20)
    scale = 0
    notification_limit = 6
    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    indicate_hidden = yes
    transparency = 0
    separator_height = 2
    padding = 14
    horizontal_padding = 14
    text_icon_padding = 10
    frame_width = 2
    frame_color = "#7fbbb3"
    gap_size = 8
    separator_color = frame
    sort = yes
    word_wrap = yes
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes
    icon_position = left
    min_icon_size = 20
    max_icon_size = 40
    corner_radius = 0
    sticky_history = yes
    history_length = 20
    browser = xdg-open
    always_run_script = true
    title = Dunst
    class = Dunst
    markup = full
    format = "<b>%s</b>\n%b"
    font = CaskaydiaCove Nerd Font Mono 10

[urgency_low]
    background = "#2d353b"
    foreground = "#859289"
    frame_color = "#3d484d"
    timeout = 4

[urgency_normal]
    background = "#2d353b"
    foreground = "#d3c6aa"
    frame_color = "#7fbbb3"
    timeout = 6

[urgency_critical]
    background = "#2d353b"
    foreground = "#e67e80"
    frame_color = "#e67e80"
    timeout = 0
